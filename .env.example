# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# LLM Configuration (Vertex AI / Gemini)
ENABLE_LLM_EXPLANATIONS=false
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
CREDENTIALS_FILE_PATH=path/to/service-account.json

# Model Configuration
